# .env.example - Copy to .env and fill in values

# PostgreSQL
POSTGRES_DB=omni_desk
POSTGRES_USER=user
POSTGRES_PASSWORD=<change-me>
DB_HOST=db
DB_PORT=5432

# Django
SECRET_KEY=<generate-a-secure-key>
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# CORS / CSRF (adjust for your deployment)
# CSRF_TRUSTED_ORIGIN_PROD=http://your-domain
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
# CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# paperless-ngx 集成(详见 docs/technical/XX-paperless-integration.md)
PAPERLESS_DB_PASSWORD=<change-me-paperless-db>
PAPERLESS_SECRET_KEY=<change-me-paperless-sk>
# PAPERLESS_API_TOKEN=<your-paperless-admin-api-token>
# PAPERLESS_URL=http://paperless:8000
