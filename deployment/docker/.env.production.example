# Production environment variables for OmniDesk
# ================================================
# 1. Copy this file to .env.production:
#    cp .env.production.example .env.production
# 2. Fill in ALL empty values below with real secrets.
# 3. NEVER commit .env.production to version control.

# ── PostgreSQL ──────────────────────────────────────────────
# Database name (safe to keep)
POSTGRES_DB=omni_desk
# Database username (must be set)
POSTGRES_USER=
# Database password — use a strong password (min 16 chars)
POSTGRES_PASSWORD=
# Host and port of the PostgreSQL service (match docker-compose)
DB_HOST=db
DB_PORT=5432

# ── Django ──────────────────────────────────────────────────
# Django secret key — generate with:
#   python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=
# Must be False in production
DEBUG=False
# Comma-separated list of allowed hostnames/IPs
DJANGO_ALLOWED_HOSTS=
# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=
# Comma-separated list of trusted CSRF origins
CSRF_TRUSTED_ORIGINS=

# ── Redis ───────────────────────────────────────────────────
# Redis password — must match the --requirepass in docker-compose
REDIS_PASSWORD=
REDIS_HOST=redis
REDIS_PORT=6379

# ── Celery ──────────────────────────────────────────────────
# These use REDIS_PASSWORD above — no need to change the format
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/0
