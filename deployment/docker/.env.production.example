# Production environment variables for OmniDesk
# ================================================
# 这是部署 OmniDesk 生产/离线环境所需的全部环境变量模板。
#
# 使用步骤:
#   1. 复制本文件为 .env.production:
#      cp .env.production.example .env.production
#   2. 填写所有 <CHANGE-TO-...> / <GENERATE-...> / <YOUR_...> 占位符为真实值。
#   3. 永不要把 .env.production 提交到版本控制。
#
# 字段分组:
#   - PostgreSQL / Redis: 数据库与缓存凭证
#   - Django: 应用密钥 + 允许的主机/CORS
#   - Docker 镜像标签: 部署哪个版本的镜像
#   - Celery: 异步任务队列
#   - Mineru: 文档解析服务(可选,不配置 = 该功能禁用,其他功能不受影响)
#
# 占位符说明:
#   - <CHANGE-TO-STRONG-PASSWORD>: 至少 16 字符的强密码
#   - <CHANGE-TO-DB-USER>: 数据库用户名
#   - <GENERATE-NEW-SECRET-KEY>: 用 `python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"` 生成
#   - <YOUR_MINERU_API_KEY>: 从 Mineru 服务获取的真实 API Key;留空 = 禁用文档解析

# ── PostgreSQL ──────────────────────────────────────────────
# Database name (safe to keep)
POSTGRES_DB=omni_desk
# Database username (must be set)
POSTGRES_USER=<CHANGE-TO-DB-USER>
# Database password — use a strong password (min 16 chars)
POSTGRES_PASSWORD=<CHANGE-TO-STRONG-PASSWORD>
# Host and port of the PostgreSQL service (match docker-compose service name)
DB_HOST=db
DB_PORT=5432

# ── Django ──────────────────────────────────────────────────
# Django secret key — generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=<GENERATE-NEW-SECRET-KEY>
# Must be False in production
DEBUG=False
# Comma-separated list of allowed hostnames/IPs
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
# Comma-separated list of trusted CSRF origins
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
# USE_HTTPS: true=启用 HTTPS 全套安全加固;false=纯 HTTP 部署(默认,内网常用)
#   - true:  nginx/反代必须正确转发 X-Forwarded-Proto 头
#   - false: SECURE_SSL_REDIRECT/HSTS 关闭,允许 cookie 在 HTTP 下传输
USE_HTTPS=false

# ── Docker Image Tags ───────────────────────────────────────
# 使用语义版本标签(参见 deployment/docker/VERSION),不要用 :latest
# CI (build-and-push-images.yml) 会在 main 分支推送时打 v{VERSION} 标签
BACKEND_IMAGE_TAG=v0.2.0
FRONTEND_IMAGE_TAG=v0.2.0

# ── Redis ───────────────────────────────────────────────────
# Redis password — must match the --requirepass in docker-compose
REDIS_PASSWORD=<CHANGE-TO-STRONG-PASSWORD>
REDIS_HOST=redis
REDIS_PORT=6379

# ── Celery ──────────────────────────────────────────────────
# These use REDIS_PASSWORD above — no need to change the format
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/0
CACHE_REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/1

# ── Mineru (文档解析服务,可选) ────────────────────────────────
# 离线/内网环境应指向内网 Mineru 服务。
# 不配置或留空 = 文档解析功能不可用,不影响其他功能。
# production.py 会在 KEY 为占位符时报错;留空或填真实 KEY 都可以。
# MINERU_API_KEY=<YOUR_MINERU_API_KEY>
# MINERU_API_URL=http://mineru-service:8000/api/v1
