# .env.production.example - Copy to .env.production and fill in values

# PostgreSQL
POSTGRES_DB=omni_desk
POSTGRES_USER=<change-me>
POSTGRES_PASSWORD=<change-me>
DB_HOST=db
DB_PORT=5432

# Django
SECRET_KEY=<generate-a-secure-key>
DEBUG=False
DJANGO_ALLOWED_HOSTS=<your-production-domain>
CORS_ALLOWED_ORIGINS=http://localhost:3000,<your-frontend-domain>

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# CSRF
CSRF_TRUSTED_ORIGINS=http://localhost:3000,<your-frontend-domain>
