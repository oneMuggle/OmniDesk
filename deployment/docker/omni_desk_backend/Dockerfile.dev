# Base image for development
FROM python:3.11-slim

# Set environment variables to prevent generating .pyc files and to buffer output
ENV PYTHONDONTWRITEBYTECODE 1
ENV PYTHONUNBUFFERED 1

# Set the working directory in the container
WORKDIR /usr/src/app

# Copy the requirements file and install dependencies
# The build context is assumed to be the project root.
COPY omni_desk_backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# The command to run the application will be provided by docker-compose
# This allows for flexibility, e.g., running migrations then the server.