# .env for local development and docker-compose

# PostgreSQL
POSTGRES_DB=omni_desk
POSTGRES_USER=user
POSTGRES_PASSWORD=password
DB_HOST=db
DB_PORT=5432

# Django
SECRET_KEY='django-insecure-your-default-secret-key-for-development'
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CSRF_TRUSTED_ORIGIN_PROD=http://113.44.214.144
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,7.18.60.2