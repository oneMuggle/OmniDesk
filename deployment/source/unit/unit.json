{
    "listeners": {
        "*:80": {
            "pass": "routes"
        }
    },

    "routes": [
        {
            "match": {
                "uri": "/api/*"
            },
            "action": {
                "pass": "applications/django"
            }
        },
        {
            "action": {
                "share": "/var/www/omni_desk/frontend_build/",
                "fallback": {
                    "share": "/var/www/omni_desk/frontend_build/index.html"
                }
            }
        }
    ],

    "applications": {
        "django": {
            "type": "python 3.10",
            "path": "/var/www/omni_desk/omni_desk_backend",
            "home": "/var/www/omni_desk/venv",
            "module": "omni_desk_backend.wsgi"
        }
    }
}