# Git
.git
.gitignore

# Node.js / Frontend
node_modules
omni_desk_frontend/
!omni_desk_frontend/public/routes.json
package.json
package-lock.json
.npmignore

# Python cache and virtual environments
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
omni_desk_backend/python/
omni_desk_backend/venv/
venv/
*.venv

# IDE and OS specific files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Documentation
docs/
tech_docs/
*.md

# Deployment & Config files not needed in the image
deployment/
docker/
nginx_config/
scripts/
misc/
# Exception: VERSION file is needed by core/version.py to report deployed version
!deployment/docker/VERSION

# Project specific tooling
.roo/
.trae/
.cospec/

# Other logs and artifacts
nohup.out